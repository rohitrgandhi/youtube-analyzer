from flask import Flask, render_template, request, jsonify, send_file
from flask_cors import CORS
import threading
import time
from diary_exact_analyzer import DiaryExactAnalyzer
from diary_exact_report import generate_exact_report
import config

app = Flask(__name__)
CORS(app)

tasks = {}

class Task:
    def __init__(self, task_id):
        self.task_id = task_id
        self.status = "running"
        self.progress = 0
        self.message = "Starting..."
        self.result = None
        self.error = None

def run_analysis(task_id, channel):
    task = tasks[task_id]
    try:
        task.progress = 10
        task.message = "Initializing analyzer..."
        analyzer = DiaryExactAnalyzer(config.YOUTUBE_API_KEY, config.OPENAI_API_KEY, config.MODEL)
        
        task.progress = 20
        task.message = f"Finding {channel}..."
        channel_id = analyzer.get_channel_id(channel)
        if not channel_id:
            task.status = "error"
            task.error = "Channel not found"
            return
        
        task.progress = 30
        task.message = "Fetching videos..."
        videos = analyzer.get_all_videos(channel_id, 200)
        
        task.progress = 40
        task.message = "Categorizing videos..."
        categorized = analyzer.categorize_videos(videos)
        
        # Safety check: Need at least 5 podcast episodes to analyze
        if len(categorized['all']) < 5:
            task.status = "error"
            task.error = f"Not enough podcast/interview content found. Only {len(categorized['all'])} videos 15+ min. Need at least 5 for meaningful analysis. Try a different channel with more long-form content."
            return
        
        task.progress = 50
        task.message = "Analyzing guest fame (18.9x gap)..."
        guest_fame = analyzer.analyze_guest_fame(categorized['all'])
        
        task.progress = 60
        task.message = "Counting questions (6.28x gap)..."
        questions = analyzer.analyze_questions(categorized['all'])
        
        task.progress = 65
        task.message = "Analyzing title structure (95.1%)..."
        title_structure = analyzer.analyze_title_structure(categorized['all'])
        
        task.progress = 70
        task.message = "Measuring title length (-10.7 chars)..."
        title_length = analyzer.analyze_title_length(categorized['all'])
        
        task.progress = 75
        task.message = "Finding duration sweet spot..."
        duration = analyzer.analyze_duration_buckets(categorized['all'])
        
        task.progress = 85
        task.message = "Analyzing topic framing (4.14x)..."
        topics = analyzer.analyze_topics(categorized['all'])
        
        task.progress = 90
        task.message = "Comparing hook types..."
        hooks = analyzer.analyze_hook_types(categorized['all'])
        
        task.progress = 95
        task.message = "Generating crisp report..."
        
        analyses = {
            'guest_fame': guest_fame,
            'questions': questions,
            'title_structure': title_structure,
            'title_length': title_length,
            'duration': duration,
            'topics': topics,
            'hooks': hooks
        }
        
        html_file = generate_exact_report(categorized, analyses)
        
        task.status = "complete"
        task.progress = 100
        task.result = {
            'html_file': html_file,
            'stats': {
                'total': len(categorized['all']),
                'shorts': len(categorized['shorts']),
                'regular': len(categorized['regular']),
                'podcasts': len(categorized['podcasts'])
            }
        }
    except Exception as e:
        task.status = "error"
        task.error = str(e)
        print(f"Error: {e}")
        import traceback
        traceback.print_exc()

@app.route('/')
def index():
    return render_template('index.html')

@app.route('/api/analyze', methods=['POST'])
def analyze():
    data = request.json
    channel = data.get('channel', '').strip()
    task_id = f"{channel}_{int(time.time())}"
    tasks[task_id] = Task(task_id)
    thread = threading.Thread(target=run_analysis, args=(task_id, channel))
    thread.daemon = True
    thread.start()
    return jsonify({'task_id': task_id})

@app.route('/api/progress/<task_id>')
def get_progress(task_id):
    task = tasks.get(task_id)
    if not task:
        return jsonify({'error': 'Not found'}), 404
    return jsonify({
        'status': task.status,
        'progress': task.progress,
        'message': task.message,
        'error': task.error,
        'result': task.result
    })

@app.route('/api/report/<path:filename>')
def serve_report(filename):
    return send_file(f'youtube_analysis_data/{filename}')

if __name__ == '__main__':
    print("\n" + "="*70)
    print("📊 DIARY OF A CEO - EXACT METHODOLOGY ANALYZER")
    print("="*70)
    print("\nAnalysis:")
    print("  1. Fame (18.9x gap)")
    print("  2. Questions (6.28x gap, effect size 2.03)")
    print("  3. Title Structure (85.4% name/frame, 95.1% colons)")
    print("  4. Title Length (-10.7 chars)")
    print("  5. Duration Sweet Spot (60-90 min, 5.35x)")
    print("  6. Topic Framing (4.14x crime vs health)")
    print("  7. Hook Types (48.8% proof vs 43.9% pain)")
    print("\n🎯 Crisp, data-driven insights with takeaways")
    print("\nOpen: http://localhost:8080\n")
    app.run(host='0.0.0.0', port=8080, debug=False)
